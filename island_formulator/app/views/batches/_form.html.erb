<%= form_with(model: @batch, class: "contents") do |form| %>
  <% if batch.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(batch.errors.count, "error") %> prohibited this batch from being saved:</h2>

      <ul class="list-disc ml-6">
        <% batch.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

<%= form.hidden_field :recipe_id, value: @batch.recipe_id || params[:recipe_id] %>
<%= form.date_field :made_on, value: @batch.made_on || Date.today %>


  <div class="inline mt-3">
    <%= form.submit "Log Batch", 
    class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  
  </div>
<% end %>
